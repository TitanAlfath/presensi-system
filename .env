# Default Preset Configuration
# Enter your Firebase Credentials here to connect to live Firestore.
# If left empty, the application runs in a feature-rich Local Simulation mode.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Admin Dashboard Access Passcode (Used for Login.jsx)
VITE_ADMIN_PASSCODE=123456


